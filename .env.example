# ── Cấu hình FaceAttend ──
# Copy file này thành .env và điền thông tin thật

# Camera
CAMERA_ID=0                    # 0 = webcam mặc định, 1 = camera ngoài

# AI
FACE_THRESHOLD=0.50            # Ngưỡng nhận diện (0.0 - 1.0)
COOLDOWN_MINUTES=5             # Thời gian chờ giữa 2 lần chấm công

# Giờ làm việc
WORK_START=08:30               # Giờ bắt đầu (HH:MM)
WORK_END=17:30                 # Giờ kết thúc

# Email thông báo (Gmail)
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=app_password_here    # Bật 2FA → Tạo App Password
EMAIL_TO=admin@company.com

# Telegram Bot
TELEGRAM_TOKEN=123456:ABC-DEF       # Lấy từ @BotFather
TELEGRAM_CHAT_ID=-100123456789      # ID group hoặc user

# Server
HOST=0.0.0.0
PORT=8000
