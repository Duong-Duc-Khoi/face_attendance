# ── Database ──────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=face_attendance

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_32_char_string
ACCESS_TOKEN_EXP=15        # phút
REFRESH_TOKEN_EXP=10080    # phút (7 ngày)
OTP_EXP_MINUTES=10

# ── Camera ────────────────────────────────────────────
CAMERA_ID=0                # 0 = webcam mặc định

# ── AI / Face Engine ─────────────────────────────────
FACE_THRESHOLD=0.50        # Ngưỡng nhận diện (0.0 - 1.0)
MIN_FACE_SIZE=40           # px
OPENAI_API_KEY=            # Tuỳ chọn: bật AI đề xuất phân ca
OPENAI_MODEL=gpt-4.1-mini

# ── Chấm công ─────────────────────────────────────────
COOLDOWN_MINUTES=5         # Thời gian chờ giữa 2 lần chấm công
WORK_START=08:30
WORK_END=17:30

# ── Email (Gmail SMTP) ────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=app_password_here   # Bật 2FA → Tạo App Password
EMAIL_TO=admin@company.com         # Nhận báo cáo ngày

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
BASE_URL=http://localhost:8000
